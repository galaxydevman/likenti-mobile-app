{
  "expo": {
    "name": "Likenti",
    "owner": "antony596",
    "slug": "likenti",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon/likenti_logo_transparent_white.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.likentistore.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon/likenti_logo_transparent_white.png"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "46326694-5f9e-4ade-9ded-0d44b2b8a9e2"
      }
    }
  }
}
