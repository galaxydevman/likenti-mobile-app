# Copy to `.env` in this folder and restart Expo.
# Use the Storefront API access token from Shopify Admin → Settings → Apps and sales channels
# → Develop apps → [your app] → API credentials → Storefront API access token.
# Do NOT put the Admin API client secret or OAuth token in the mobile app.

EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=likenti.myshopify.com
EXPO_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
